# ============================================================
# Auto Research - Environment Variables Example
# Copy this file to .env and fill in your values.
# When deploying on Manus Platform, these are injected automatically.
# ============================================================

# --- Manus Platform (auto-injected on Manus) ---
VITE_APP_ID=your_manus_app_id
JWT_SECRET=your_jwt_secret
DATABASE_URL=mysql://user:password@host:3306/dbname
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://manus.im
OWNER_OPEN_ID=your_owner_open_id
OWNER_NAME=your_owner_name

# --- Manus Built-in APIs (auto-injected on Manus) ---
BUILT_IN_FORGE_API_URL=https://forge.manus.ai
BUILT_IN_FORGE_API_KEY=your_forge_api_key
VITE_FRONTEND_FORGE_API_KEY=your_frontend_forge_api_key
VITE_FRONTEND_FORGE_API_URL=https://forge.manus.ai

# --- External APIs (optional, improves literature search coverage) ---
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key
SPRINGER_API_KEY=your_springer_api_key

# --- Analytics (optional, Manus Platform analytics) ---
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
